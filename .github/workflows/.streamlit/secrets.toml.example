# ================================================================
# .streamlit/secrets.toml — TEMPLATE ONLY
# ================================================================
# DO NOT commit this file to GitHub (it's in .gitignore)
#
# HOW TO USE THIS FILE:
# For local testing: rename to secrets.toml and fill in your keys
# For Streamlit Cloud: add these keys in the Streamlit web interface
# (App Settings → Secrets)
#
# WHERE TO GET EACH KEY:
# GEMINI_API_KEY → https://aistudio.google.com/app/apikey
# GROQ_API_KEY → https://console.groq.com/keys
# ================================================================

# Your Google Gemini API Key (FREE - no credit card needed)
GEMINI_API_KEY = "paste_your_gemini_key_here"

# Your Groq API Key (FREE backup AI)
GROQ_API_KEY = "paste_your_groq_key_here"
